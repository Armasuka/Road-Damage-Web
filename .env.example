# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: PostgreSQL connection string from Supabase (Settings -> Database -> Connection string -> URI)
DATABASE_URL="postgres://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# Optional, for frontend usage if needed:
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJhb..."

# ULTRALYTICS_API_KEY: Required to access the custom YOLO model
ULTRALYTICS_API_KEY="ul_myAPIkey"