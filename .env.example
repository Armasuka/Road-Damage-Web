# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: PostgreSQL connection string from Supabase (Settings -> Database -> Connection string -> URI)
DATABASE_URL="postgres://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# SMTP (Gmail) - untuk kirim email notifikasi ke warga
# Gmail: need app password (https://myaccount.google.com/apppasswords)
# NOTE: Gmail has 500 emails/day limit, use Resend/SendGrid for production
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="armasuka10@gmail.com"
SMTP_PASS="pvbq ttdp ncso wntl"

# Optional: custom from email address
FEEDBACK_FROM_EMAIL="JALUR Kemang <noreply@jalur.local>"

# ULTRALYTICS_API_KEY: Required to access the custom YOLO model
ULTRALYTICS_API_KEY="ul_myAPIkey"