# Database connection string (PostgreSQL)
# Format: postgresql://username:password@host:port/database
# Example: postgresql://admin:MyPassword123@db.example.com:5432/mydb
#
# Note: If your password contains special characters like @, #, !, etc,
# wrap the password in square brackets: postgresql://admin:[My@Password]@db.example.com:5432/mydb
DATABASE_URL=postgresql://user:password@host:port/database